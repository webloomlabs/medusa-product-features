{
  "name": "@webloomlabs/product-features",
  "version": "0.1.1",
  "description": "Medusa v2 plugin to manage a global catalog of product features (title, subtitle, icon) and assign them, ordered, to products.",
  "author": "WebLoomLabs",
  "license": "MIT",
  "homepage": "https://github.com/webloomlabs/medusa-product-features#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webloomlabs/medusa-product-features.git"
  },
  "bugs": {
    "url": "https://github.com/webloomlabs/medusa-product-features/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-other",
    "medusa-plugin",
    "medusa-v2"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "lint": "medusa lint",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/eslint-plugin": "2.17.2",
    "@medusajs/framework": "2.17.2",
    "@medusajs/icons": "2.17.2",
    "@medusajs/medusa": "2.17.2",
    "@medusajs/test-utils": "2.17.2",
    "@medusajs/ui": "4.1.19",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "eslint": "^9.0.0",
    "jiti": "^2.0.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/framework": "2.17.2",
    "@medusajs/icons": "2.17.2",
    "@medusajs/medusa": "2.17.2",
    "@medusajs/test-utils": "2.17.2",
    "@medusajs/ui": "4.1.19"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.8.0"
}
